{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/health",
      "destination": "/api/index.ts"
    },
    {
      "source": "/init",
      "destination": "/api/index.ts"
    },
    {
      "source": "/pages",
      "destination": "/api/index.ts"
    },
    {
      "source": "/pages/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/shutdown",
      "destination": "/api/index.ts"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/((?!api|health|init|pages|shutdown|assets|favicon.ico|icon.png|video.mp4|aura_intro.mp4).*)",
      "destination": "/index.html"
    }
  ]
}
